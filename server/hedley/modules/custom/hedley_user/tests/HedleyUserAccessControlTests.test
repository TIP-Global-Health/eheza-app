<?php

/**
 * @file
 * Combined access control tests.
 *
 * Merges HedleyActivityEndpoints and HedleyUserNodePermissions into a single
 * test class to reduce the number of Drupal installs in CI.
 */

/**
 * HedleyUserAccessControlTests.
 */
class HedleyUserAccessControlTests extends HedleyWebTestBase {

  /**
   * The profile name.
   *
   * @var string
   */
  protected $profile = 'hedley';

  /**
   * A user object.
   *
   * @var object
   */
  protected $user;

  /**
   * Anonymous user object.
   *
   * @var object
   */
  protected $anonymousUser;

  /**
   * {@inheritdoc}
   */
  public function setUp() {
    // Enable all hedley modules that define node types and permissions.
    // This is the union of modules needed by both endpoint and permission
    // tests.
    $modules = array(
      'hedley_activity',
      'hedley_acute_illness',
      'hedley_admin',
      'hedley_case_management',
      'hedley_chw',
      'hedley_device',
      'hedley_forms',
      'hedley_general',
      'hedley_group_education',
      'hedley_health_center',
      'hedley_hiv',
      'hedley_ncd',
      'hedley_ncda',
      'hedley_nutrition',
      'hedley_patient',
      'hedley_person',
      'hedley_prenatal',
      'hedley_reports',
      'hedley_resilience',
      'hedley_schedule',
      'hedley_stats',
      'hedley_stock_management',
      'hedley_tuberculosis',
      'hedley_well_child',
      'hedley_whatsapp',
      'hedley_zscore',
    );

    parent::setUp($modules);

    // Common test users for endpoint tests.
    $this->anonymousUser = user_load(0);
    $this->user = $this->drupalCreateUser(['bypass node access']);
  }

  /**
   * Info hook.
   */
  public static function getInfo() {
    return [
      'name' => 'HedleyAccessControlTests',
      'description' => 'Tests REST endpoints and node permissions for administrator and sync users.',
      'group' => 'Hedley',
    ];
  }

  /**
   * Testing the entry point of the photos.
   */
  public function testPhotosEndpoint() {
    $photo = $this->drupalCreateNode(['type' => 'photo']);

    /** @var RestfulEntityBaseNode $handler */
    $handler = restful_get_restful_handler('photos');

    // Make sure anonymous user doesn't get the content.
    $handler->setAccount($this->anonymousUser);
    $anonymous_results = $handler->get('');
    $this->assertFalse($anonymous_results, 'Anonymous user doesn\'t have access to the "photo" content.');

    // Test authorized user.
    $handler->setAccount($this->user);

    $results = $handler->get('');
    $this->assertEqual($results[0]['created'], date('c', $photo->created), 'Photo "created date" is correct.');

  }

  /**
   * Testing the entry point of the Nutrition Signs.
   */
  public function testNutritionsEndpoint() {
    $nutrition = $this->drupalCreateNode(['type' => 'nutrition']);

    /** @var RestfulEntityBaseNode $handler */
    $handler = restful_get_restful_handler('nutritions');

    // Make sure anonymous user doesn't get the content.
    $handler->setAccount($this->anonymousUser);
    $anonymous_results = $handler->get('');
    $this->assertFalse($anonymous_results, 'Anonymous user doesn\'t have access to the "nutrition" content.');

    // Test authorized user.
    $handler->setAccount($this->user);

    $results = $handler->get('');
    $this->assertEqual($results[0]['created'], date('c', $nutrition->created), 'Nutrition "created date" is correct.');

  }

  /**
   * Testing the entry point of the muacs.
   */
  public function testMuacsEndpoint() {
    $muac = $this->drupalCreateNode(['type' => 'muac']);

    /** @var RestfulEntityBaseNode $handler */
    $handler = restful_get_restful_handler('muacs');

    // Make sure anonymous user doesn't get the content.
    $handler->setAccount($this->anonymousUser);
    $anonymous_results = $handler->get('');
    $this->assertFalse($anonymous_results, 'Anonymous user doesn\'t have access to the "muac" content.');

    // Test authorized user.
    $handler->setAccount($this->user);

    $results = $handler->get('');
    $this->assertEqual($results[0]['created'], date('c', $muac->created), 'Muac "created date" is correct.');
  }

  /**
   * Get all node types dynamically from the system.
   *
   * @return array
   *   Array of node type machine names.
   */
  protected function getNodeTypes() {
    $node_types = array();
    foreach (node_type_get_types() as $type) {
      $node_types[] = $type->type;
    }
    return $node_types;
  }

  /**
   * Test that administrator users have all 5 permissions for each node type.
   */
  public function testAdministratorPermissions() {
    $administrator_role = user_role_load_by_name('administrator');
    $this->assertTrue($administrator_role, 'Administrator role exists');

    $permissions = user_role_permissions(array($administrator_role->rid => $administrator_role));
    $admin_permissions = isset($permissions[$administrator_role->rid]) ? $permissions[$administrator_role->rid] : array();

    $node_types = $this->getNodeTypes();

    foreach ($node_types as $node_type) {
      // Administrator should have all 5 permissions.
      $expected_permissions = array(
        "create $node_type content",
        "edit own $node_type content",
        "edit any $node_type content",
        "delete own $node_type content",
        "delete any $node_type content",
      );

      foreach ($expected_permissions as $permission) {
        $this->assertTrue(
          isset($admin_permissions[$permission]),
          "Administrator has permission: $permission"
        );
      }
    }
  }

  /**
   * Verify RESTful handlers cover all encounter and measurement content types.
   */
  public function testShardedHandlersCoverage() {
    $encounter_types = hedley_general_get_encounter_types();
    $measurement_types = hedley_general_get_measurement_types();
    $sharded = array_keys(HEDLEY_RESTFUL_SHARDED);

    $missing_encounters = array_values(array_diff($encounter_types, $sharded));
    $missing_measurements = array_values(array_diff($measurement_types, $sharded));

    $this->assertIdentical([], $missing_encounters, format_string('Missing RESTful handlers for encounter types: @bundles', ['@bundles' => implode(', ', $missing_encounters)]));
    $this->assertIdentical([], $missing_measurements, format_string('Missing RESTful handlers for measurement types: @bundles', ['@bundles' => implode(', ', $missing_measurements)]));

    $this->assertHandlersResolvable(array_unique(array_merge($encounter_types, $measurement_types)));
  }

  /**
   * Assert handlers are resolvable for provided bundles.
   *
   * @param array $bundles
   *   Bundles to validate.
   */
  protected function assertHandlersResolvable(array $bundles) {
    foreach ($bundles as $bundle) {
      $handler_name = HEDLEY_RESTFUL_SHARDED[$bundle];

      try {
        $handler = restful_get_restful_handler($handler_name);
        $this->assertTrue(is_object($handler), format_string('Handler @handler available for bundle @bundle.', ['@handler' => $handler_name, '@bundle' => $bundle]));
      }
      catch (Exception $e) {
        $this->fail(format_string('Missing RESTful handler @handler for bundle @bundle: @message', [
          '@handler' => $handler_name,
          '@bundle' => $bundle,
          '@message' => $e->getMessage(),
        ]));
      }
    }
  }

  /**
   * Test that sync users have 3 permissions for each node type.
   */
  public function testSyncPermissions() {
    $sync_role = user_role_load_by_name('sync');
    $this->assertTrue($sync_role, 'Sync role exists');

    $permissions = user_role_permissions(array($sync_role->rid => $sync_role));
    $sync_permissions = isset($permissions[$sync_role->rid]) ? $permissions[$sync_role->rid] : array();

    $node_types = $this->getNodeTypes();

    foreach ($node_types as $node_type) {
      if (in_array($node_type, array('device', 'report_data'))) {
        // Sync does not have permissions for these node types.
        continue;
      }

      // Sync should have 3 permissions.
      $expected_permissions = array(
        "create $node_type content",
        "edit own $node_type content",
        "edit any $node_type content",
      );

      foreach ($expected_permissions as $permission) {
        $this->assertTrue(
          isset($sync_permissions[$permission]),
          "Sync has permission: $permission"
        );
      }

      // Sync should NOT have delete permissions.
      $forbidden_permissions = array(
        "delete own $node_type content",
        "delete any $node_type content",
      );

      foreach ($forbidden_permissions as $permission) {
        $this->assertFalse(
          isset($sync_permissions[$permission]),
          "Sync does NOT have permission: $permission"
        );
      }
    }
  }

  /**
   * Switch global $user to the given account, returning the previous one.
   *
   * The /api/reports-data access check reads global $user (via
   * hedley_reports_resolve_scope_for_reports_by_current_user and
   * hedley_ncda_aggregated_ncda_report_access). In production those globals
   * are set by Restful's auth providers; in this direct-call test we set
   * them ourselves.
   */
  protected function switchUser($account) {
    global $user;
    $original = $user;
    $user = $account;
    drupal_save_session(FALSE);
    return $original;
  }

  /**
   * Restore global $user to the given account.
   */
  protected function restoreUser($account) {
    global $user;
    $user = $account;
    drupal_save_session(TRUE);
  }

  /**
   * Invoke /api/reports-data as the given account.
   *
   * Returns the response array, or NULL if RestfulForbiddenException was
   * thrown (the access check we're exercising).
   */
  protected function invokeReportsDataAsUser($account, array $request) {
    $handler = restful_get_restful_handler('reports-data');
    $handler->setAccount($account);
    $handler->setRequest($request);

    $original = $this->switchUser($account);
    try {
      return $handler->getData();
    }
    catch (\RestfulForbiddenException $e) {
      return NULL;
    } finally {
      $this->restoreUser($original);
    }
  }

  /**
   * Grant a role by name to the given account, then reload it.
   */
  protected function grantRole($account, $role_name) {
    $role = user_role_load_by_name($role_name);
    $account->roles[$role->rid] = $role->name;
    user_save($account);
    return user_load($account->uid, TRUE);
  }

  /**
   * Test /api/reports-data denies users without the required role.
   */
  public function testReportsDataUnprivilegedUserDenied() {
    $user = $this->drupalCreateUser();

    foreach (['reports', 'completion', 'scoreboard'] as $app_type) {
      $request = ['app_type' => $app_type, 'base_revision' => 0];
      $result = $this->invokeReportsDataAsUser($user, $request);
      $this->assertNull($result, "Unprivileged user denied for app_type=$app_type.");
    }
  }

  /**
   * Test /api/reports-data: SQM grants reports/completion only.
   */
  public function testReportsDataStatisticalQueriesManagerAccess() {
    $sqm = $this->grantRole($this->drupalCreateUser(), 'Statistical Queries Manager');

    foreach (['reports', 'completion'] as $app_type) {
      $request = ['app_type' => $app_type, 'base_revision' => 0];
      $result = $this->invokeReportsDataAsUser($sqm, $request);
      $this->assertNotNull($result, "SQM allowed for app_type=$app_type.");
      $this->assertTrue(
        isset($result['batch']) && isset($result['total_remaining']) && isset($result['last']),
        "SQM response has expected sync shape for app_type=$app_type."
      );
    }

    // SQM does NOT have Data Manager role -> denied for scoreboard.
    $request = ['app_type' => 'scoreboard', 'base_revision' => 0];
    $result = $this->invokeReportsDataAsUser($sqm, $request);
    $this->assertNull($result, 'SQM denied for app_type=scoreboard.');
  }

  /**
   * Test /api/reports-data: Data Manager grants scoreboard only.
   */
  public function testReportsDataDataManagerAccess() {
    $dm = $this->grantRole($this->drupalCreateUser(), 'Data Manager');

    $request = ['app_type' => 'scoreboard', 'base_revision' => 0];
    $result = $this->invokeReportsDataAsUser($dm, $request);
    $this->assertNotNull($result, 'Data Manager allowed for app_type=scoreboard.');

    // Data Manager does NOT have SQM role -> denied for reports/completion.
    foreach (['reports', 'completion'] as $app_type) {
      $request = ['app_type' => $app_type, 'base_revision' => 0];
      $result = $this->invokeReportsDataAsUser($dm, $request);
      $this->assertNull($result, "Data Manager denied for app_type=$app_type.");
    }
  }

  /**
   * Test /api/reports-data: HC-scoped SQM may only request their own HC.
   */
  public function testReportsDataHcScopedStatisticalQueriesManager() {
    $allowed_hc = $this->createHealthCenter();
    $foreign_hc = $this->createHealthCenter();

    $sqm = $this->grantRole($this->drupalCreateUser(), 'Statistical Queries Manager');
    $wrapper = entity_metadata_wrapper('user', $sqm);
    $wrapper->field_health_centers_for_reports->set([$allowed_hc]);
    $wrapper->save();
    $sqm = user_load($sqm->uid, TRUE);

    // Allowed HC -> success.
    $request = [
      'app_type' => 'reports',
      'base_revision' => 0,
      'health_center' => $allowed_hc,
    ];
    $result = $this->invokeReportsDataAsUser($sqm, $request);
    $this->assertNotNull($result, 'HC-scoped SQM allowed for own HC.');

    // Foreign HC -> denied.
    $request = [
      'app_type' => 'reports',
      'base_revision' => 0,
      'health_center' => $foreign_hc,
    ];
    $result = $this->invokeReportsDataAsUser($sqm, $request);
    $this->assertNull($result, 'HC-scoped SQM denied for foreign HC.');

    // Missing HC -> denied (HC-scoped users must specify their HC).
    $request = ['app_type' => 'reports', 'base_revision' => 0];
    $result = $this->invokeReportsDataAsUser($sqm, $request);
    $this->assertNull($result, 'HC-scoped SQM denied when health_center is missing.');
  }

  /**
   * Create a file entity for use as a signature.
   *
   * @return object
   *   The file object.
   */
  protected function createSignatureFile() {
    $filename = 'test-signature-' . $this->randomName() . '.png';
    $file = new stdClass();
    $file->uri = 'public://' . $filename;
    $file->filename = $filename;
    $file->filemime = 'image/png';
    $file->status = FILE_STATUS_PERMANENT;
    // Create a minimal PNG so the file physically exists.
    file_put_contents($file->uri, base64_decode('iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=='));
    file_save($file);
    return $file;
  }

  /**
   * Create a stock_update node.
   *
   * UUID is auto-generated by hedley_device_assign_uuid().
   *
   * @param int $health_center_id
   *   The health center node ID.
   * @param int $nurse_id
   *   The nurse (person) node ID.
   * @param int $village_id
   *   Optional village node ID.
   *
   * @return object
   *   The stock_update node.
   */
  protected function createStockUpdate($health_center_id, $nurse_id, $village_id = NULL) {
    $file = $this->createSignatureFile();

    $node = $this->drupalCreateNode(['type' => 'stock_update']);
    $wrapper = entity_metadata_wrapper('node', $node);
    $wrapper->field_nurse->set($nurse_id);
    $wrapper->field_health_center->set($health_center_id);
    $wrapper->field_date_measured->set(REQUEST_TIME);
    $wrapper->field_quantity->set(100);
    $wrapper->field_stock_update_type->set('receive-supply');
    $wrapper->field_signature->set(['fid' => $file->fid]);

    if ($village_id) {
      $wrapper->field_village_ref->set($village_id);
    }

    $wrapper->save();

    // Reload to get the auto-generated UUID.
    $node = node_load($node->nid, NULL, TRUE);
    return $node;
  }

  /**
   * Test stock_update with village_ref via REST endpoint.
   */
  public function testStockUpdateWithVillageRef() {
    $user = $this->drupalCreateUser(['bypass node access']);

    // Create health center.
    $hc_node = $this->drupalCreateNode(['type' => 'health_center']);
    $this->assertTrue(!empty($hc_node->nid), 'Health center node created.');
    $health_center_id = $hc_node->nid;

    // Create nurse (person).
    $nurse_node = $this->drupalCreateNode(['type' => 'person']);
    $nurse_wrapper = entity_metadata_wrapper('node', $nurse_node);
    $nurse_wrapper->field_second_name->set('Test');
    $nurse_wrapper->field_gender->set('male');
    $nurse_wrapper->field_birth_date->set(strtotime('1990-01-01'));
    $nurse_wrapper->save();
    $nurse_node = node_load($nurse_node->nid, NULL, TRUE);
    $nurse_uuid = entity_metadata_wrapper('node', $nurse_node)->field_uuid->value();

    // Create village. Set fields via field API to avoid entity wrapper
    // validation issues in test environment.
    $village_node = $this->drupalCreateNode([
      'type' => 'village',
      'field_health_center' => [
        LANGUAGE_NONE => [
          ['target_id' => $health_center_id],
        ],
      ],
      'field_province' => [LANGUAGE_NONE => [['value' => 'Test']]],
      'field_district' => [LANGUAGE_NONE => [['value' => 'Test']]],
      'field_sector' => [LANGUAGE_NONE => [['value' => 'Test']]],
      'field_cell' => [LANGUAGE_NONE => [['value' => 'Test']]],
      'field_village' => [LANGUAGE_NONE => [['value' => 'Test']]],
    ]);
    $village_node = node_load($village_node->nid, NULL, TRUE);
    $village_uuid = entity_metadata_wrapper('node', $village_node)->field_uuid->value();

    // Create stock_update with village_ref.
    $stock_update_with = $this->createStockUpdate($health_center_id, $nurse_node->nid, $village_node->nid);
    $with_village_uuid = entity_metadata_wrapper('node', $stock_update_with)->field_uuid->value();

    // Create stock_update without village_ref.
    $stock_update_without = $this->createStockUpdate($health_center_id, $nurse_node->nid);
    $without_village_uuid = entity_metadata_wrapper('node', $stock_update_without)->field_uuid->value();

    // Fetch via REST handler.
    /** @var \RestfulEntityBaseNode $handler */
    $handler = restful_get_restful_handler('stock-update');
    $handler->setAccount($user);
    $results = $handler->get('');

    $this->assertTrue(is_array($results) && count($results) >= 2, 'At least 2 stock updates returned.');

    $found_with_village = FALSE;
    $found_without_village = FALSE;
    foreach ($results as $result) {
      if ($result['uuid'] === $with_village_uuid) {
        $found_with_village = TRUE;
        $this->assertEqual($result['village_ref'], $village_uuid, 'village_ref contains correct village UUID.');
        $this->assertEqual($result['nurse'], $nurse_uuid, 'nurse field contains correct UUID.');
        $this->assertEqual($result['quantity'], 100, 'quantity is correct.');
      }
      if ($result['uuid'] === $without_village_uuid) {
        $found_without_village = TRUE;
        $this->assertNull($result['village_ref'], 'village_ref is NULL when no village is set.');
      }
    }

    $this->assertTrue($found_with_village, 'Stock update with village_ref found in response.');
    $this->assertTrue($found_without_village, 'Stock update without village_ref found in response.');
  }

  /**
   * Test feature flags in sync endpoint.
   */
  public function testFeatureFlags() {
    $user = $this->drupalCreateUser(['bypass node access']);

    // Enable both stock management features.
    variable_set('hedley_admin_feature_stock_management_hc_enabled', TRUE);
    variable_set('hedley_admin_feature_stock_management_village_enabled', TRUE);

    /** @var \HedleyRestfulSync $handler */
    $handler = restful_get_restful_handler('sync');
    $handler->setAccount($user);
    $handler->setRequest([
      'base_revision' => 0,
      'db_version' => HEDLEY_RESTFUL_CLIENT_SIDE_INDEXEDDB_SCHEMA_VERSION,
    ]);
    $result = $handler->getForAllDevices();

    $features = explode(' ', $result['features']);
    $this->assertTrue(in_array('stock_management_hc', $features), 'stock_management_hc feature is reported when enabled.');
    $this->assertTrue(in_array('stock_management_village', $features), 'stock_management_village feature is reported when enabled.');

    // Disable village feature and verify it disappears.
    variable_set('hedley_admin_feature_stock_management_village_enabled', FALSE);

    $result = $handler->getForAllDevices();
    $features = explode(' ', $result['features']);
    $this->assertTrue(in_array('stock_management_hc', $features), 'stock_management_hc still reported after village disabled.');
    $this->assertFalse(in_array('stock_management_village', $features), 'stock_management_village not reported when disabled.');
  }

}
